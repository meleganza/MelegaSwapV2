{
  "git": {
    "deploymentEnabled": {
      "main": true,
      "home-trade-screen-redesign": true,
      "design-system-foundation": true,
      "mission-project-os-p0-remediation": true,
      "mission-pp-cert-project-os-certification": true
    }
  },
  "rewrites": [
    {
      "source": "/@:slug",
      "destination": "/project-hq/:slug"
    },
    {
      "source": "/@:slug/",
      "destination": "/project-hq/:slug/"
    }
  ],
  "crons": [
    {
      "path": "/api/indexer/run/",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/indexer/registry/refresh/",
      "schedule": "0 3 * * *"
    }
  ],
  "functions": {
    "apps/web/src/pages/api/indexer/run.ts": {
      "maxDuration": 300
    },
    "apps/web/src/pages/api/indexer/registry/refresh.ts": {
      "maxDuration": 300
    }
  }
}