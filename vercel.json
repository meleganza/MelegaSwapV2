{
  "git": {
    "deploymentEnabled": {
      "main": true,
      "home-trade-screen-redesign": true,
      "design-system-foundation": true
    }
  },
  "crons": [
    {
      "path": "/api/indexer/run/",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/indexer/registry/refresh/",
      "schedule": "0 3 * * *"
    }
  ],
  "functions": {
    "apps/web/src/pages/api/indexer/run.ts": {
      "maxDuration": 300
    },
    "apps/web/src/pages/api/indexer/registry/refresh.ts": {
      "maxDuration": 300
    }
  }
}