# Melega Smart Router Wrapper — Foundry deploy pipeline (root)
# Copy to .env and fill before broadcast. Never commit .env.

# --- Deployer credentials (hex private key, no 0x prefix optional) ---
TESTNET_DEPLOYER=
MAINNET_DEPLOYER=
DEPLOYER_OWNER=

# --- RPC endpoints ---
BNB_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545
BNB_MAINNET_RPC_URL=https://bsc-dataseed.binance.org

# --- Explorer verification (BscScan API key) ---
BSCSCAN_API_KEY=
# Deprecated typo alias (some env files):
BSCSCAN_API_KEY=

# --- Constructor inputs (required for broadcast; NULL blocks dry-run) ---
# Chain 56 mainnet defaults in smart-router registry
# Chain 97 testnet MARCO (R744B Treasury Runtime confirmed):
# MARCO_TOKEN=0x963556de0eb8138E97A85F0A86eE0acD159D210b
UNDERLYING_ROUTER=
TREASURY_INTAKE=
# Alias for treasury intake address:
TREASURY_COLLECTOR=
MARCO_TOKEN=

# --- Optional post-deploy (publish scripts only; not used by forge deploy) ---
WRAPPER_ADDRESS=
WRAPPER_CHAIN_ID=56
